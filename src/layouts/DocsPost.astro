---
import Base from './Base.astro';
const { frontmatter } = Astro.props;

const sections = [
  { title: "Installation",  href: "#installation" },
  { title: "Project setup", href: "#project-setup" },
  { title: "Plant",         href: "#plant" },
  { title: "Measurement",   href: "#measurement" },
  { title: "Controller",    href: "#controller" },
  { title: "Simulator",      href: "#simulator" },
  { title: "ScenarioLoader", href: "#scenarioloader" },
  { title: "PatientLoader",   href: "#cohortloader" },
  { title: "Evaluator",      href: "#evaluator" },
  { title: "Optimizer",     href: "#optimizer" },
];
---
<Base title={`${frontmatter.title} — AXON Docs`} description={frontmatter.description}>
<style>
  :root {
    --bg:      #141414;
    --surface: #1e1e1e;
    --accent:  #57c4b8;
    --text:    #d4d4d4;
    --muted:   #6a6a6a;
    --border:  rgba(212,212,212,0.1);
    --sidebar-width: 200px;
  }

  nav { border-bottom: 1px solid var(--border); padding: 1.25rem 0; position: sticky; top: 0; background: var(--bg); z-index: 10; }
  .nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; }
  .logo { font-family: monospace; font-size: 1.1rem; font-weight: 700; letter-spacing: 0.15em; color: var(--accent); text-transform: uppercase; text-decoration: none; }
  .nav-right a { color: var(--muted); text-decoration: none; font-size: 0.875rem; margin-left: 2rem; transition: color 0.2s; }
  .nav-right a:hover { color: var(--text); }

  .docs-layout { max-width: 1100px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: var(--sidebar-width) 1fr; gap: 4rem; align-items: start; }

  .sidebar { position: sticky; top: 4.5rem; padding: 3rem 0 6rem; }
  .sidebar-label { font-family: monospace; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
  .sidebar nav { border-bottom: none; padding: 0; position: static; background: none; }
  .sidebar-links { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .sidebar-links li a { display: block; font-size: 0.85rem; color: var(--muted); text-decoration: none; padding: 0.35rem 0; border-left: 2px solid transparent; padding-left: 0.75rem; transition: color 0.15s, border-color 0.15s; }
  .sidebar-links li a:hover { color: var(--text); }
  .sidebar-links li a.active { color: var(--accent); border-left-color: var(--accent); }

  main { padding: 3rem 0 6rem; min-width: 0; }

  .page-label { font-family: monospace; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; color: #f0f0f0; line-height: 1.15; margin-bottom: 0.5rem; }
  .page-desc { color: var(--muted); font-size: 0.9rem; margin-bottom: 2.5rem; }

  .prose { color: var(--text); }
  .prose h2 { font-size: 1.3rem; font-weight: 700; color: #f0f0f0; margin: 3rem 0 0.75rem; letter-spacing: -0.01em; padding-top: 0.5rem; border-top: 1px solid var(--border); scroll-margin-top: 5rem; }
  .prose h2:first-of-type { margin-top: 0; border-top: none; }
  .prose h3 { font-size: 1rem; font-weight: 600; color: #f0f0f0; margin: 1.75rem 0 0.5rem; }
  .prose p { margin-bottom: 1.25rem; font-size: 0.95rem; line-height: 1.75; }
  .prose a { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(87,196,184,0.3); }
  .prose a:hover { border-color: var(--accent); }
  .prose code { font-family: monospace; font-size: 0.85em; background: var(--surface); padding: 0.15em 0.4em; color: var(--accent); }
  .prose pre { background: var(--surface) !important; border: 1px solid var(--border); padding: 1.25rem !important; overflow-x: auto; margin-bottom: 1.5rem; font-size: 12px !important; }
  .prose pre code { background: none; padding: 0; color: var(--text); font-size: 12px !important; line-height: 1.7; }
  .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose li { margin-bottom: 0.4rem; font-size: 0.95rem; line-height: 1.75; }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .prose blockquote { border-left: 2px solid var(--accent); padding-left: 1rem; color: var(--muted); margin-bottom: 1.25rem; }
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .prose th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--accent); color: #f0f0f0; font-weight: 600; }
  .prose td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); }

  /* Step callout */
  .prose .step-run { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--accent); padding: 1rem 1.25rem; margin: 1.5rem 0; font-size: 0.875rem; }
  .prose .step-run .step-label { font-family: monospace; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }

  footer { border-top: 1px solid var(--border); padding: 2rem; color: var(--muted); font-size: 0.78rem; }
  footer .inner { max-width: 1100px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; }
  footer a { color: var(--muted); text-decoration: none; }
  footer a:hover { color: var(--accent); }

  @media (max-width: 720px) {
    .docs-layout { grid-template-columns: 1fr; gap: 0; }
    .sidebar { display: none; }
  }
</style>
<style is:global>
  .prose .astro-code, .prose .astro-code span { font-size: 12px !important; }
  .prose p { margin-bottom: 1.25rem; font-size: 0.95rem; line-height: 1.75; }
  .prose h2 { font-size: 1.3rem; font-weight: 700; color: #f0f0f0; margin: 3rem 0 0.75rem; letter-spacing: -0.01em; scroll-margin-top: 5rem; }
  .prose h3 { font-size: 1rem; font-weight: 600; color: #f0f0f0; margin: 1.75rem 0 0.5rem; }
  .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose li { margin-bottom: 0.4rem; font-size: 0.95rem; line-height: 1.75; }
  .prose hr { border: none; border-top: 1px solid rgba(212,212,212,0.1); margin: 2.5rem 0; }
</style>

<nav>
  <div class="nav-inner">
    <a class="logo" href="/">AXON</a>
    <div class="nav-right">
      <a href="/learn">Learn</a>
      <a href="/blog">Blog</a>
      {import.meta.env.DEV && <a href="/quickstart">Docs</a>}
    </div>
  </div>
</nav>

<div class="docs-layout">
  <aside class="sidebar">
    <p class="sidebar-label">Myelin Docs</p>
    <ul class="sidebar-links">
      {sections.map(s => (
        <li><a href={s.href}>{s.title}</a></li>
      ))}
    </ul>
  </aside>

  <main>
    <p class="page-label">Myelin</p>
    <h1>{frontmatter.title}</h1>
    {frontmatter.description && <p class="page-desc">{frontmatter.description}</p>}
    <div class="prose">
      <slot />
    </div>
  </main>
</div>

<footer>
  <div class="inner">
    <span>AXON &copy; 2026</span>
    <a href="/">runaxon.com</a>
  </div>
</footer>

<script is:inline>
  // Highlight active sidebar link based on scroll position
  const links = document.querySelectorAll('.sidebar-links a');
  const headings = document.querySelectorAll('.prose h2[id]');

  function onScroll() {
    let current = '';
    headings.forEach(h => {
      if (h.getBoundingClientRect().top <= 120) current = h.id;
    });
    links.forEach(a => {
      a.classList.toggle('active', a.getAttribute('href') === '#' + current);
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
</Base>
