---
import Base from '../layouts/Base.astro';
import '../styles/index.css';
---
<Base
  title="AXON: Simulation Infrastructure"
  description="Scalable simulation infrastructure for regulated science."
>


<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AXON",
  "url": "https://runaxon.com",
  "description": "Scalable simulation infrastructure for regulated science.",
  "applicationCategory": "ScientificApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Sign up for development updates"
  },
  "provider": {
    "@type": "Organization",
    "name": "AXON",
    "url": "https://runaxon.com"
  }
}
</script>

<nav>
  <div class="container">
    <a class="logo" href="/">AXON</a>
    <div class="nav-links">
      <a href="#myelin">Myelin</a>
      <a href="/blog">Blog</a>
      <a href="#waitlist" class="cta">Receive Updates</a>
    </div>
  </div>
</nav>

<main>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Simulation Infrastructure</p>
      <h1>Scalable<br>simulation infrastructure<br>for <em>regulated science</em>.</h1>
      <p class="hero-sub">Currently in development. Join the waitlist for updates or reach out directly at anthony@runaxon.com</p>
      <div class="cta-group">
        <a href="#waitlist" class="btn btn-primary">Receive Updates</a>
        <a href="#myelin" class="btn btn-secondary">Powered by Myelin</a>
      </div>
    </div>
  </section>

  <section class="myelin" id="myelin">
    <div class="container">
      <div class="myelin-inner">
        <div>
          <p class="myelin-label">Start for free</p>
          <h2>Begin with Myelin.<br>Scale with AXON.</h2>
          <p>Myelin is a free VS Code extension that transpiles your Python simulation code to optimized C modules.</p>
          <p>It automatically profiles your code, identifies bottlenecks, transpiles to C, and validates correctness.</p>
          <p>AXON is the final step, where your optimized simulation code is run at scale in our cloud infrastructure specifically tailored for regulated simulations.</p>
          <span class="btn-myelin btn-myelin-disabled">coming soon</span>
        </div>
        <div class="code-block">
          <span class="code-label before">your_sim.py</span>
          <pre class="code-body before" set:html={`<span class="c-text">def run_ode(t, y, params):\n    dydt = params[0] * y[0]\n    \u2026\n    return dydt</span>`}></pre>
          <div class="code-arrow">save &#x2193;</div>
          <span class="code-label after">.forge/run_ode.c — generated</span>
          <pre class="code-body after" set:html={`<span class="c-green">// equivalence: PASSED (1024 cases)\n// speedup:     8.3x</span>\n\n<span class="c-text">double run_ode(double t,\n               double* y,\n               double* params) {\n    \u2026\n}</span>`}></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="waitlist" id="waitlist">
    <div class="container">
      <p class="section-label">Stay in the loop</p>
      <h2>Sign up for development updates.</h2>
      <p class="section-sub">AXON is in development. Sign up and we'll keep you updated.</p>
      <form name="waitlist" method="POST" data-netlify="true" action="/success">
        <input type="hidden" name="form-name" value="waitlist">
        <div class="form-row">
          <div class="field">
            <label>Name <span class="optional">optional</span></label>
            <input type="text" name="name" placeholder="Jane Smith">
          </div>
          <div class="field">
            <label>Email <span style="color:var(--accent);font-size:0.65rem;">*</span></label>
            <input type="email" name="email" placeholder="jane@lab.org" required>
          </div>
        </div>
        <div class="field">
          <label>What are you simulating? <span class="optional">optional</span></label>
          <textarea name="simulation" placeholder="e.g. TCI controller optimization using Schnider pk/pd model"></textarea>
        </div>
        <div class="form-submit">
          <button type="submit" class="btn btn-primary" style="width:100%">Receive Updates</button>
        </div>
        <p class="form-note">I will only reach out when there is something worth sharing.</p>
      </form>
    </div>
  </section>
</main>

<footer>
  <div class="container">
    <span>AXON © 2026</span>
    <span>Built for PK/PD at scale.</span>
  </div>
</footer>
</Base>
